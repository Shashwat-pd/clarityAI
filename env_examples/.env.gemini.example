# Gemini-only LLM configuration with Deepgram-hosted audio models

# Set up your Gemini API key here: https://ai.google.dev/
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# Gemini model used for the interviewer itself
LLM_URL=https://generativelanguage.googleapis.com
LLM_TYPE=GEMINI_API
LLM_NAME=gemini-2.5-flash

# Set up your Deepgram API key here: https://developers.deepgram.com/
DEEPGRAM_API_KEY=YOUR_DEEPGRAM_API_KEY

# Nova-3 is Deepgram's transcription model
STT_URL=https://api.deepgram.com/v1/listen
STT_TYPE=DEEPGRAM_API
STT_NAME=nova-3

# Aura is Deepgram's text-to-speech family
TTS_URL=https://api.deepgram.com/v1/speak
TTS_TYPE=DEEPGRAM_API
TTS_NAME=aura-2-thalia-en
